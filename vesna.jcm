mas vesna {

    agent alice:alice.asl {
        ag-class:   vesna.VesnaAgent
        temper:     temper(cautious(0.2), bold(0.3), curious(0.5), excited(0.2)[mood], satisfied(-0.5)[mood], content(0.3)[mood])
        address:    localhost
        port:       9080
        strategy:   random
        reward_machine: true
        goals:      start
    }

}
